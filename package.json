{
  "name": "vidyapath",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:strict": "next lint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "check:all": "npm run typecheck && npm run lint && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security-guards": "node scripts/security_assertions.mjs",
    "build:context": "python scripts/build_context_index.py --max-files 0",
    "build:context:node": "node scripts/build_context_index.mjs",
    "build:context:python": "python scripts/build_context_index.py --max-files 0",
    "build:context:python:fast": "python scripts/build_context_index.py --max-files 220",
    "build:textbooks": "python scripts/build_textbook_index.py --merge-main-index",
    "build:vectors": "node scripts/build_vector_index.mjs",
    "build:rag": "npm run build:context && npm run build:textbooks && npm run build:vectors",
    "build:rag:clean": "npm run build:context && npm run build:textbooks && npm run clean:chunks && npm run build:vectors",
    "clean:chunks": "node scripts/clean_context_chunks.mjs",
    "verify:context": "node scripts/verify_context_index.mjs",
    "check:auth-matrix": "node scripts/auth_matrix_smoke.mjs",
    "check:auth-suite": "node scripts/auth_role_isolation_suite.mjs",
    "check:route-links": "node scripts/route_link_integrity.mjs",
    "check:data-quality": "node scripts/check_dataset_quality.mjs",
    "migrate:supabase-state": "node scripts/migrate_state_to_supabase.mjs",
    "migrate:teacher-normalized": "node scripts/migrate_teacher_blob_to_normalized.mjs",
    "seed:career-map": "node scripts/seed_chapter_career_map.mjs",
    "check:supabase-teacher": "node scripts/check_supabase_teacher_setup.mjs",
    "reset:supabase-soft": "node scripts/soft_reset_supabase.mjs",
    "seed:supabase-mock": "node scripts/seed_supabase_mock_data.mjs",
    "seed:auth-users": "node scripts/seed_auth_users.mjs",
    "db:clear": "node scripts/clear_supabase_db.mjs",
    "db:reset-full": "node scripts/clear_supabase_db.mjs && node scripts/seed_supabase_mock_data.mjs && node scripts/seed_auth_users.mjs",
    "fix:pin-hashes": "node scripts/fix_plain_pin_hashes.mjs",
    "fix:pin-hashes:apply": "node scripts/fix_plain_pin_hashes.mjs --apply",
    "hf:upload:cbse": "python scripts/upload_to_hf.py --repo-id AdithyaSNair/cbse-papers-2009-2025 --folder dataset/cbse_papers",
    "hf:upload:ncert": "python scripts/upload_to_hf.py --repo-id AdithyaSNair/ncert-textbooks-10-12 --folder dataset/ncert_textbooks",
    "db:push": "npx supabase db push",
    "db:diff": "npx supabase db diff",
    "db:reset": "npx supabase db reset",
    "db:new": "npx supabase migration new",
    "db:pull": "npx supabase db pull",
    "db:status": "npx supabase migration list",
    "db:lint": "npx supabase db lint"
  },
  "dependencies": {
    "@serwist/next": "^9.5.7",
    "@supabase/supabase-js": "^2.103.3",
    "@types/web-push": "^3.6.4",
    "@upstash/redis": "^1.37.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.400.0",
    "mermaid": "^11.14.0",
    "next": "14.2.5",
    "pino": "^10.3.1",
    "react": "^18",
    "react-dom": "^18",
    "react-katex": "^3.1.0",
    "serwist": "^9.5.7",
    "swr": "^2.4.1",
    "ts-fsrs": "^5.3.2",
    "use-debounce": "^10.1.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-katex": "^3.0.4",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "xlsx": "npm:@e965464e/xlsx@^0.20.3"
  }
}
