# Get your FREE Groq API key at: https://console.groq.com
# No credit card required. 14,400 requests/day free.
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
# Optional: override NVIDIA endpoints if needed
# NVIDIA_INTEGRATE_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_AI_BASE_URL=https://ai.api.nvidia.com/v1
# Optional: enable NVIDIA reranker for context retrieval
# AI_ENABLE_NVIDIA_RERANK=1
# AI_RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2

# Optional: model routing overrides (aliases are defined in lib/ai/model-routing.ts)
# AI_TASK_MODEL_CHAT=G4,GLM5,GEMINI_FLASH
# AI_TASK_MODEL_MCQ=G4,GLM5
# AI_TASK_MODEL_MAP={"chat":["G4","M27","GLM5"],"paper-evaluate":["GLM5","M27","G4"]}
TEACHER_PORTAL_KEY=replace_with_teacher_secret
ADMIN_PORTAL_KEY=replace_with_admin_secret
SESSION_SIGNING_SECRET=replace_with_long_random_string_required_in_all_envs
SINGLE_ENV_MODE=1
# Legacy HMAC cookie sessions: enabled by default for backward compatibility.
# Set to false after all portals are fully migrated to Supabase Auth.
# AUTH_ENABLE_LEGACY_SESSIONS=false
# Optional CSRF origin pinning list (comma-separated)
# CSRF_ALLOWED_ORIGINS=https://vidyapath.in,https://www.vidyapath.in
# Optional canonical app origin for CSRF checks
# NEXT_PUBLIC_APP_URL=https://vidyapath.in
# Rate-limit fallback behavior: defaults fail-closed in production, fail-open in non-production
# RATE_LIMIT_FAIL_OPEN=false
# Keep disabled unless you must support legacy middleware role-hint behavior
# ENABLE_SUPABASE_ROLE_HINT_COOKIE=0
# Optional developer login (defaults in non-production:
# username=developer@vidyapath, password=Developer@Vidyapath.org)
# DEVELOPER_USERNAME=developer@vidyapath
# DEVELOPER_PASSWORD=Developer@Vidyapath.org
# Optional fixed test credentials (for seeded auth users)
# TEST_STUDENT_EMAIL=student@vidyapath
# TEST_STUDENT_PASSWORD=Student@Vidyapath.org
# TEST_TEACHER_EMAIL=teacher@vidyapath
# TEST_TEACHER_PASSWORD=Teacher@Vidyapath.org
# TEST_ADMIN_EMAIL=admin@vidyapath
# TEST_ADMIN_PASSWORD=Admin@Vidyapath.org
# STRICT_ENV_VALIDATION=1

# Optional credential email delivery (Resend)
# RESEND_API_KEY=re_xxx
# AUTH_MAIL_FROM=Vidyapath Auth <auth@your-domain.com>

# Optional privacy analytics (choose one or both)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=vidyapath.vercel.app
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://your-umami-domain/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id

# Supabase Auth + multi-school platform (required for role-aware v2)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key (supported fallback)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# DEFAULT_SCHOOL_CODE=VIDYAPATH-001

# Optional: Supabase persistence for analytics + teacher data (recommended on Vercel)
# SUPABASE_STATE_TABLE=app_state
# SUPABASE_STATE_SCHEMA=public

# Required for normalized admin/teacher platform
# Run scripts/sql/supabase_init.sql in Supabase SQL editor

# ── Rate limiting (optional — falls back to Supabase DB when absent) ──────
# Sign up free at https://upstash.com → Redis → REST API
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ── AI context bundle (optional — run npm run build:context to generate) ──
# Upload lib/context/chunks.jsonl to Supabase Storage or a CDN and set:
# CONTEXT_BUNDLE_URL=https://your-bucket.supabase.co/storage/v1/object/public/context/chunks.jsonl

# ── Observability ──────────────────────────────────────────────────────────
# LOG_LEVEL=info   (trace | debug | info | warn | error | fatal | silent)

# ── AI cost guardrails ─────────────────────────────────────────────────────
# Hard upper-bound tokens per single AI request (default 4000; max 32768)
# AI_MAX_TOKENS_PER_REQUEST=4000
# Daily token budget per school (default 100,000)
# AI_DAILY_TOKEN_BUDGET_PER_SCHOOL=100000
# Global daily token cap across all schools (default 1,000,000)
# AI_DAILY_TOKEN_BUDGET_GLOBAL=1000000

# \u2500\u2500\u2500 pgvector / RAG \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
# Enable pgvector in Supabase Dashboard \u2192 Extensions, then apply migration
# 20260418000600_pgvector_document_embeddings.sql, then seed embeddings:
#   node scripts/ingest_embeddings.mjs --skip-existing
#
# NVIDIA_API_KEY is reused for query embeddings at retrieval time (see above).
# Fallback OpenAI embeddings (text-embedding-3-small, 1024-dim truncated):
# OPENAI_API_KEY=sk-...
# Admin trigger endpoint (local dev only): POST /api/admin/embeddings
