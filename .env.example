# Get your FREE Groq API key at: https://console.groq.com
# No credit card required. 14,400 requests/day free.
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
# Optional: override NVIDIA endpoints if needed
# NVIDIA_INTEGRATE_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_AI_BASE_URL=https://ai.api.nvidia.com/v1
# Optional: enable NVIDIA reranker for context retrieval
# AI_ENABLE_NVIDIA_RERANK=1
# AI_RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2

# Optional: model routing overrides (aliases are defined in lib/ai/model-routing.ts)
# AI_TASK_MODEL_CHAT=G4,GLM5,GEMINI_FLASH
# AI_TASK_MODEL_MCQ=G4,GLM5
# AI_TASK_MODEL_MAP={"chat":["G4","M27","GLM5"],"paper-evaluate":["GLM5","M27","G4"]}
TEACHER_PORTAL_KEY=replace_with_teacher_secret
ADMIN_PORTAL_KEY=replace_with_admin_secret
SESSION_SIGNING_SECRET=replace_with_long_random_string
SINGLE_ENV_MODE=1
# STRICT_ENV_VALIDATION=1

# Optional privacy analytics (choose one or both)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=vidyapath.vercel.app
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://your-umami-domain/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id

# Supabase Auth + multi-school platform (required for role-aware v2)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key (supported fallback)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# DEFAULT_SCHOOL_CODE=VIDYAPATH-001

# Optional: Supabase persistence for analytics + teacher data (recommended on Vercel)
# SUPABASE_STATE_TABLE=app_state
# SUPABASE_STATE_SCHEMA=public

# Required for normalized admin/teacher platform
# Run scripts/sql/supabase_init.sql in Supabase SQL editor
