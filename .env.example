# Get your FREE Groq API key at: https://console.groq.com
# No credit card required. 14,400 requests/day free.
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
TEACHER_PORTAL_KEY=replace_with_teacher_secret
ADMIN_PORTAL_KEY=replace_with_admin_secret
SESSION_SIGNING_SECRET=replace_with_long_random_string

# Optional privacy analytics (choose one or both)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=vidyapath.vercel.app
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://your-umami-domain/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id

# Optional: Supabase (not needed for v1)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Supabase persistence for analytics + teacher data (recommended on Vercel)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_STATE_TABLE=app_state
# SUPABASE_STATE_SCHEMA=public

# Required for normalized admin/teacher platform
# Run scripts/sql/supabase_init.sql in Supabase SQL editor
